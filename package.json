{
  "name": "@gittan/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BloomerAB/gittan-api.git"
  },
  "dependencies": {
    "@gittan/types": "^0.10.0",
    "@bloomerab/npm-api-essentials": "^1.3.0",
    "cassandra-driver": "^4.7.2",
    "express": "^5.1.0",
    "nats": "^2.29.3",
    "openapi-types": "^12.1.3",
    "pdfkit": "^0.19.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.32.1"
}
